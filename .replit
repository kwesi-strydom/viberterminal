modules = ["nodejs-20"]
hidden = [".next", "node_modules"]

# Modern Replit workspaces expose port 5000 by default. Bind explicitly so
# the dev server is reachable through Replit's proxy.
run = "[ -d node_modules ] || npm install; npm run dev -- -p 5000 -H 0.0.0.0"

[nix]
channel = "stable-24_05"

[env]
NODE_ENV = "development"
NEXT_TELEMETRY_DISABLED = "1"
PORT = "5000"

[packager]
language = "nodejs"

[packager.features]
packageSearch = true
guessImports = true

[[ports]]
localPort = 5000
externalPort = 80

# Production deploy: build + serve. Replit's Cloud Run target supplies $PORT.
[deployment]
run = ["sh", "-c", "npm install && npm run build && npm run start -- -H 0.0.0.0 -p ${PORT:-5000}"]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm install && npm run build"]
