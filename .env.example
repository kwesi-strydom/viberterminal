# Viber Terminal env

# Postgres connection string (Neon / Replit Postgres / local).
# Leave empty in v1 dev — the app falls back to an in-memory portal store.
DATABASE_URL=

# Public base URL (used for portal thumbnails / share links).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Hero video URL. Defaults to /hero.mp4 (local file in /public).
# Override with a CDN URL for production (the local file is gitignored
# because it's >100 MB).
NEXT_PUBLIC_HERO_VIDEO_URL=/hero.mp4
